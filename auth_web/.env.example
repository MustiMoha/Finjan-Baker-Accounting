# Required for Vercel production builds (set in Vercel → Settings → Environment Variables).
# After changing any VITE_* variable, redeploy — values are baked in at build time.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key
VITE_API_URL=https://ali-al-baker-api.fly.dev
VITE_STREAMLIT_URL=https://ali-al-baker-streamlit.fly.dev

# Optional for local Vite dev only (npm run dev proxies /api to port 8000).
# Normal local startup uses start.py, which reads .streamlit/secrets.toml.
