# Local development: copy to .streamlit/secrets.toml (see Streamlit secrets docs)
# Production (Vercel + Fly.io): set the same keys as env vars — see deploy/DEV_SETUP.md
# https://docs.streamlit.io/develop/concepts/connections/secrets

SUPABASE_URL=https://your-project.supabase.co
# Legacy JWT anon (eyJ...) or publishable (sb_publishable_... — needs supabase>=2.22.4, see requirements.txt).
SUPABASE_ANON_KEY=your-anon-key
# Service role key — required for Streamlit handoff + promote_org_admin.py (never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local: FastAPI on 8000. Production API on Fly: set AUTH_WEB_URL to your Vercel app URL on the API app.
AUTH_WEB_URL=http://127.0.0.1:8000
STREAMLIT_URL=http://127.0.0.1:8501

# Fly.io API only (Vercel hosts the React app):
# SERVE_AUTH_UI=false
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-*.vercel.app

# Vercel (auth_web) build-time — set in Vercel project settings, not secrets.toml:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_API_URL=https://ali-al-baker-api.fly.dev
# VITE_STREAMLIT_URL=https://ali-al-baker-streamlit.fly.dev

# Supabase Storage: private bucket accounting-master is created via migration.
# MASTER_WORKBOOK_BUCKET=accounting-master
# Private bucket for invoices + statement templates (migration accounting-documents).
# DOCUMENTS_BUCKET=accounting-documents
# Fallback object path when app_settings.master_workbook_file_id is empty (no leading slash):
# MASTER_WORKBOOK_STORAGE_PATH=master/accounting_master.xlsm

# JPEG/PNG invoice OCR (Windows installer): https://github.com/UB-Mannheim/tesseract/wiki
# Optional — put same key in Streamlit secrets as TESSERACT_CMD if tesseract.exe is not on PATH.
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe